---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contact" class="py-20 px-4">
  <div class="max-w-3xl mx-auto bg-[#0F0F0F]/50 border border-white/10 p-8 rounded-2xl backdrop-blur-sm">
    <h2 class="text-xl md:text-3xl font-bold text-white mb-2 text-center">{t('contact.title')}</h2>
    <p class=" text-gray-400 text-center mb-8">{t('contact.subtitle')}</p>

    <form id="contact-form" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">{t('contact.name')}</label>
          <input type="text" name="name" required class="w-full bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-white focus:border-green-500 focus:outline-none transition-colors" placeholder="your name">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Email</label>
          <input type="email" name="email" required class="w-full bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-white focus:border-green-500 focus:outline-none transition-colors" placeholder="your@email.com">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">{t('contact.message')}</label>
        <textarea name="message" rows="4" required class="w-full bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-white focus:border-green-500 focus:outline-none transition-colors" placeholder="How can I help you?"></textarea>
      </div>
      <button type="submit" id="submit-btn" class="w-full bg-accent text-bg font-bold py-4 rounded-lg transition-all transform hover:scale-[1.02] active:scale-95 cursor-pointer">
         {t('contact.sendMessage')}
      </button>
    </form>
  </div>
</section>

<script>
  import Swal from 'sweetalert2';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const originalText = btn?.innerText;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    btn.disabled = true;
    btn.innerText = "..."; 

    const formData = new FormData(form);

    try {
      const response = await fetch('https://formspree.io/f/xpqkyykj', {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      });

      if (response.ok) {
        
        Swal.fire({
          title: '¡Send successfully!',
          text: 'Your message has been sent successfully.',
          icon: 'success',
          background: '#0a1f1f', 
          color: '#ffffff',
          confirmButtonColor: '#26cc6b', 
          iconColor: '#26cc6b',
          customClass: {
            popup: 'rounded-2xl border border-white/10 backdrop-blur-md'
          }
        });
        form.reset();
      } else {
        Swal.fire({
          title: 'Error',
          text: 'Hubo un problema al enviar.',
          icon: 'error',
          background: '#0a1f1f',
          color: '#ffffff',
          confirmButtonColor: '#d97706' 
        });
      }
    } catch (error) {
      Swal.fire({
        icon: 'error',
        title: 'Sin conexión',
        text: 'Revisa tu internet e inténtalo de nuevo.',
        background: '#0a1f1f',
        color: '#ffffff'
      });
    } finally {
      btn.disabled = false;
      btn.innerText = originalText;
    }
  });
</script>