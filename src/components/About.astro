---
import Container from './Container.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="relative">
 <!-- waves -->
  <div class="absolute inset-0 opacity-10 dark:opacity-20 pointer-events-none">
    <img 
    src="/assets/icons/bg-waves.svg" 
    alt="" 
    class="w-full h-full object-cover object-center"
    />
  </div>

  <Container>
    <div class="flex flex-col items-center text-center space-y-8 md:space-y-12">
      
      <!-- Title -->
      <h2 class="text-accent text-xl md:text-2xl font-menu">
        {t('about.title')}
      </h2>

      <!-- Description -->
      <p class="text-heading text-base md:text-lg max-w-4xl leading-relaxed font-light">
        {t('about.description')}
      </p>

      <!-- Stats Cards -->
     
<div class="grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-4 w-full max-w-7xl mt-2.5">
  <div class="stat-card">
    <span class="stat-text">
      <span class="stat-number"><span id="counter-years">0</span>+</span> 
      Years of Hands-On<br />Development
    </span>
  </div>

  <div class="stat-card">
    <span class="stat-text">
      <span class="stat-number"><span id="counter-projects">0</span>+</span> 
      Real-world<br />Projects
    </span>
  </div>

  <div class="stat-card">
    <span class="stat-text">
      <span class="stat-number"><span id="counter-stack">0</span>%+</span> 
      Tech Stack<br />Mastery
    </span>
  </div>

  <div class="stat-card">
    <span class="stat-text">
      <span class="stat-number"><span id="counter-learning">0</span>%</span> 
      Continuous<br />Learning
    </span>
  </div>
</div>
    </div>
  </Container>
</section>

<style>
  .stat-card {
    position: relative;
    width: 240px;
    height: 133px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    border-radius: 16px;
    border: 2px solid transparent;
    background: linear-gradient(var(--color-bg), var(--color-bg)) padding-box,
                linear-gradient(to bottom, #F7E97C, rgba(247, 233, 124, 0.1)) border-box;
    transition: all 0.3s ease;
  }

  @media (min-width: 768px) {
    .stat-card {
      width: 260px;
      height: 150px;
    }
  }

  .stat-card:hover {
    transform: translateY(-4px);
    border-color: #F7E97C;
  }

  .stat-text {
    font-family: var(--font-menu);
    font-size: 20px;
    font-weight: 300;
    color: var(--color-heading);
    text-align: center;
    line-height: 1.3;
  }

  .stat-number {
    color: var(--color-accent2);
    font-weight: 500;
  }

  @media (min-width: 768px) {
    .stat-text {
      font-size: 22px;
    }
  }
</style>


<script>
  import { CountUp } from 'countup.js';

  // Function to initialize the counters
  function initCounters() {
    const options = {
      enableScrollSpy: true, 
      scrollSpyOnce: true,   
      duration: 2.5,         
    };

    
    new CountUp('counter-years', 3, options);
    new CountUp('counter-projects', 20, options);
    new CountUp('counter-stack', 90, options);
    new CountUp('counter-learning', 100, options);
  }

  
  document.addEventListener('astro:page-load', initCounters);
  
  initCounters();
</script>