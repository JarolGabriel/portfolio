---
const { data, institutionLogo } = Astro.props;
---

<div class="flex gap-4 py-6 border-b border-white/10 last:border-0 hover:bg-white/5 transition-colors p-4 rounded-xl group">
  <div class="shrink-0">
    <img src={institutionLogo} alt={data.title} class="w-12 h-12 object-contain rounded-md bg-white p-1" />
  </div>

  <div class="flex-1 flex flex-col gap-1">
    <div class="flex justify-between items-start">
      <div>
        <h4 class="text-white font-bold text-[16px] group-hover:text-[var(--color-yellow)] transition-colors">
          {data.title}
        </h4>
        <p class="text-gray-200 text-sm">{data.company}</p>
        <p class="text-gray-400 text-xs mt-1">Expedición: {data.date}</p>
      </div>
    </div>

    {data.credentialId && (
      <p class="text-gray-400 text-xs">ID de la credencial: {data.credentialId}</p>
    )}

    <div class="mt-3"> 
      <a 
        href={data.link} 
        target="_blank" 
        class="inline-flex items-center gap-2 px-4 py-1.5 border border-gray-400 rounded-full text-[13px] font-semibold text-gray-200 hover:border-white hover:bg-white/10 transition"
      >
        Mostrar credencial
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>

    <div class="mt-4 p-3 bg-white/5 rounded-lg border border-white/5">
      <p class="text-[13px] text-gray-300">
        <span class="font-bold text-gray-100">Aptitudes:</span> {data.skills}
      </p>
    </div>

    {data.description && (
      <div class="mt-4">
        <p class="text-sm text-gray-400 leading-relaxed italic">
          {data.description}
        </p>
      </div>
    )}
  </div>
</div>